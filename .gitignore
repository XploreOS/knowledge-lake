# Knowledge Lake — gitignore

# ── Secrets ───────────────────────────────────────────────────────────────────
.env
*.pem
*.key

# ── Local dev zone storage (MinIO is the real store) ─────────────────────────
data/

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
*.pyc

# ── uv ────────────────────────────────────────────────────────────────────────
.venv/
venv/

# ── Testing ───────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
coverage.xml
htmlcov/
.tox/

# ── Type checking ─────────────────────────────────────────────────────────────
.mypy_cache/
.dmypy.json
dmypy.json

# ── IDE / Editor ──────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# ── Docker volumes / temp ─────────────────────────────────────────────────────
docker-volumes/

# ── Ruff cache ────────────────────────────────────────────────────────────────
.ruff_cache/

# ── Hypothesis ────────────────────────────────────────────────────────────────
.hypothesis/

# ── Misc caches ───────────────────────────────────────────────────────────────
.cache/

# ── Claude Code local settings (keep .claude/CLAUDE.md tracked) ───────────────
.claude/settings.local.json
.claude/scheduled_tasks.lock

# ── Domain packs ──────────────────────────────────────────────────────────────
# Reference packs under domains/<name>/ (e.g. `healthcare`) are first-class
# source content and ARE tracked. Do NOT ignore all of domains/.
# Local / experimental packs live under domains/local/ and are NOT shipped —
# author your own here, or point KLAKE_DOMAINS_ROOT at any external directory.
/domains/local/*
!/domains/local/.gitkeep
