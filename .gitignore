# Knowledge Lake — gitignore

# ── Secrets ───────────────────────────────────────────────────────────────────
.env
*.pem
*.key

# ── Local dev zone storage (MinIO is the real store) ─────────────────────────
data/

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
*.pyc

# ── uv ────────────────────────────────────────────────────────────────────────
.venv/
venv/

# ── Testing ───────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
coverage.xml
htmlcov/
.tox/

# ── Type checking ─────────────────────────────────────────────────────────────
.mypy_cache/
.dmypy.json
dmypy.json

# ── IDE / Editor ──────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# ── Docker volumes / temp ─────────────────────────────────────────────────────
docker-volumes/

# ── Ruff cache ────────────────────────────────────────────────────────────────
.ruff_cache/


.cache/