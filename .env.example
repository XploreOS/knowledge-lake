# Knowledge Lake — environment variable template
# Copy this file to .env and fill in real values (never commit .env!)
#
# All variables use the KLAKE_ prefix (pydantic-settings env_prefix).
# Nested settings use __ as delimiter (e.g. KLAKE_STORAGE__ENDPOINT_URL).

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string (SQLAlchemy async driver)
KLAKE_DATABASE_URL=postgresql+psycopg://klake:klake@localhost:5432/klake

# ── Vector store ──────────────────────────────────────────────────────────────
KLAKE_QDRANT_URL=http://localhost:6333

# ── LiteLLM proxy ─────────────────────────────────────────────────────────────
KLAKE_LITELLM_URL=http://localhost:4000

# ── Object storage (MinIO dev / AWS S3 prod) ──────────────────────────────────
# Set KLAKE_STORAGE__ENDPOINT_URL for MinIO; leave blank for AWS S3
KLAKE_STORAGE__ENDPOINT_URL=http://localhost:9000
KLAKE_STORAGE__BUCKET=klake-data
KLAKE_STORAGE__REGION=us-east-1
# MinIO root user / AWS access key
KLAKE_STORAGE__ACCESS_KEY_ID=your-minio-root-user
# MinIO root password / AWS secret key
KLAKE_STORAGE__SECRET_ACCESS_KEY=your-minio-root-password

# ── Plugin swaps ─────────────────────────────────────────────────────────────
# embedder: local | litellm
KLAKE_EMBEDDER=local
# parser: docling
KLAKE_PARSER=docling
# vectorstore: qdrant
KLAKE_VECTORSTORE=qdrant
